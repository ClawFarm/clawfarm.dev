---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: 'Container Isolation',
    description: 'Each agent runs in its own Docker container and network. Agents can\'t see each other or reach your LAN.',
    icon: 'shield',
  },
  {
    title: 'Multi-User RBAC',
    description: 'Per-agent access control enforced at the reverse proxy layer. Users only see and manage their own agents.',
    icon: 'users',
  },
  {
    title: 'Backup & Rollback',
    description: 'Scheduled hourly backups with configurable retention. One-click restore to any previous state.',
    icon: 'archive',
  },
  {
    title: 'Zero-Config HTTPS',
    description: 'Caddy handles TLS termination with path-based routing under a single port. Four modes from self-signed to Let\'s Encrypt.',
    icon: 'lock',
  },
  {
    title: 'Monitoring',
    description: 'CPU, memory, storage, and token usage per agent. Fleet-wide stats at a glance from the dashboard.',
    icon: 'chart',
  },
  {
    title: 'Templates',
    description: 'Define reusable agent configs with environment variable substitution. Create new agents in seconds.',
    icon: 'template',
  },
];

const tlsModes = [
  {
    name: 'Internal',
    description: 'Auto-generated self-signed cert. Zero config — just deploy.',
    default: true,
  },
  {
    name: 'ACME',
    description: 'Automatic Let\'s Encrypt certificates. Set your domain and go.',
    default: false,
  },
  {
    name: 'Custom',
    description: 'Bring your own certs from an existing PKI or corporate CA.',
    default: false,
  },
  {
    name: 'Off',
    description: 'Plain HTTP. For when ClawFarm sits behind nginx, Traefik, or Cloudflare.',
    default: false,
  },
];
---

<Layout
  title="ClawFarm — Self-hosted fleet manager for OpenClaw AI agents"
  description="Deploy, monitor, and manage autonomous OpenClaw AI agents on your own hardware. Container isolation, multi-user RBAC, backup/rollback, zero-config HTTPS."
>
  <!-- Nav -->
  <nav class="fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2.5 text-lg font-semibold tracking-tight">
        <img src="/logo.svg" alt="" class="h-7 w-7" />
        ClawFarm
      </a>
      <div class="flex items-center gap-6 text-sm text-zinc-400">
        <a href="#features" class="hidden transition hover:text-zinc-100 sm:block">Features</a>
        <a href="#deploy" class="hidden transition hover:text-zinc-100 sm:block">Deploy</a>
        <a href="https://github.com/clawfarm/clawfarm" class="flex items-center gap-1.5 transition hover:text-zinc-100">
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="max-w-3xl">
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
            Self-hosted fleet manager for
            <span class="text-blue-400">OpenClaw</span>
            AI agents
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-400">
            OpenClaw is a powerful autonomous AI agent — but it's built for one operator, one instance, one CLI.
            ClawFarm gives you a web dashboard to deploy, isolate, and manage a fleet of them on your own hardware.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a
              href="#quickstart"
              class="rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-medium transition hover:bg-blue-500"
            >
              Get Started
            </a>
            <a
              href="https://github.com/clawfarm/clawfarm"
              class="rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition hover:border-zinc-500 hover:text-zinc-100"
            >
              View on GitHub
            </a>
          </div>
        </div>
      </div>

      <!-- Gradient glow behind hero -->
      <div class="pointer-events-none absolute -top-40 right-0 h-[500px] w-[500px] rounded-full bg-blue-500/5 blur-3xl"></div>
    </section>

    <!-- Screenshot -->
    <section class="mx-auto max-w-6xl px-6 pb-24">
      <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5">
        <img
          src="/screenshot-dashboard.png"
          alt="ClawFarm dashboard showing five running AI agents with status, token usage, and management controls"
          class="w-full"
          loading="lazy"
        />
      </div>
    </section>

    <!-- Quick Start -->
    <section id="quickstart" class="border-t border-zinc-800/50 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Quick Start</h2>
        <p class="mt-3 max-w-2xl text-zinc-400">Three commands. No TLS certificates to generate, no Docker GID to look up.</p>
        <div class="mt-8 overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900">
          <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-2.5 text-xs text-zinc-500">
            <span class="h-2.5 w-2.5 rounded-full bg-red-500/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/60"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-green-500/60"></span>
            <span class="ml-2">terminal</span>
          </div>
          <pre class="overflow-x-auto p-5 text-sm leading-relaxed"><code class="text-zinc-300"><span class="text-zinc-500"># Clone & configure</span>
<span class="text-blue-400">$</span> git clone https://github.com/clawfarm/clawfarm && cd clawfarm
<span class="text-blue-400">$</span> cp .env.example .env   <span class="text-zinc-500"># add your LLM provider details</span>

<span class="text-zinc-500"># Launch</span>
<span class="text-blue-400">$</span> docker compose up -d

<span class="text-zinc-500"># Open https://&lt;your-ip&gt;:8443</span>
<span class="text-zinc-500"># Admin password: docker compose logs dashboard | head -20</span></code></pre>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="border-t border-zinc-800/50 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">What you get</h2>
        <p class="mt-3 max-w-2xl text-zinc-400">
          Everything you need to run a fleet of AI agents. The AI capabilities are 100% OpenClaw — ClawFarm handles the operational infrastructure.
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {features.map((f) => (
            <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 transition hover:border-zinc-700">
              <h3 class="text-lg font-semibold">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-zinc-400">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Deployment Modes -->
    <section id="deploy" class="border-t border-zinc-800/50 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Deployment Modes</h2>
        <p class="mt-3 max-w-2xl text-zinc-400">
          Four TLS modes to fit your setup. Caddy handles all of it — you just set one env var.
        </p>
        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {tlsModes.map((mode) => (
            <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
              <div class="flex items-center gap-2">
                <h3 class="font-semibold">{mode.name}</h3>
                {mode.default && (
                  <span class="rounded-full bg-blue-500/10 px-2 py-0.5 text-xs font-medium text-blue-400">
                    default
                  </span>
                )}
              </div>
              <p class="mt-2 text-sm leading-relaxed text-zinc-400">{mode.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Provider Compatibility -->
    <section class="border-t border-zinc-800/50 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Works with any LLM</h2>
        <p class="mt-3 max-w-2xl text-zinc-400">
          Built-in templates for major providers. Any OpenAI-compatible API works too — local or cloud.
        </p>
        <div class="mt-12 grid gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
            <h3 class="font-semibold">Cloud APIs</h3>
            <p class="mt-2 text-sm text-zinc-400">Anthropic Claude, OpenAI GPT, MiniMax, Qwen — one template per provider, just add an API key.</p>
          </div>
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
            <h3 class="font-semibold">Local Models</h3>
            <p class="mt-2 text-sm text-zinc-400">vLLM, Ollama, LM Studio — use the custom-endpoint template and point to your server.</p>
          </div>
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
            <h3 class="font-semibold">Mix & Match</h3>
            <p class="mt-2 text-sm text-zinc-400">Different agents can use different providers. Run Claude for coding and GPT for research side by side.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="border-t border-zinc-800/50 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Architecture</h2>
        <p class="mt-3 max-w-2xl text-zinc-400">
          All Docker, all the way down. Dashboard, frontend, and reverse proxy run as containers. Each agent is another container with its own isolated network.
        </p>
        <div class="mt-8 overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900">
          <pre class="overflow-x-auto p-5 text-sm leading-relaxed"><code class="text-zinc-300">Browser <span class="text-zinc-500">──&gt;</span> <span class="text-blue-400">Caddy</span> <span class="text-zinc-500">(TLS + auth)</span> <span class="text-zinc-500">──&gt;</span> <span class="text-blue-400">Dashboard</span> <span class="text-zinc-500">(FastAPI)</span> <span class="text-zinc-500">──&gt;</span> <span class="text-blue-400">Bot containers</span> <span class="text-zinc-500">(OpenClaw)</span>
                                     <span class="text-zinc-500">↕</span>
                                Docker socket</code></pre>
        </div>
        <ul class="mt-6 space-y-2 text-sm text-zinc-400">
          <li><strong class="text-zinc-200">Caddy</strong> — TLS termination, path-based routing (<code class="rounded bg-zinc-800 px-1.5 py-0.5 text-xs">/claw/{'{name}'}/*</code>), forward_auth</li>
          <li><strong class="text-zinc-200">Dashboard</strong> — FastAPI backend managing bot lifecycle via Docker API</li>
          <li><strong class="text-zinc-200">Frontend</strong> — Next.js dashboard UI</li>
          <li><strong class="text-zinc-200">Bot containers</strong> — independent OpenClaw instances, one per agent, isolated networks</li>
        </ul>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-zinc-800/50 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6 text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Ready to deploy your fleet?</h2>
        <p class="mx-auto mt-3 max-w-lg text-zinc-400">
          Three commands to a running fleet. All agent data stays on your hardware.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a
            href="#quickstart"
            class="rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-medium transition hover:bg-blue-500"
          >
            Get Started
          </a>
          <a
            href="https://github.com/clawfarm/clawfarm"
            class="rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition hover:border-zinc-500 hover:text-zinc-100"
          >
            View on GitHub
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-zinc-800/50 py-8">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 text-sm text-zinc-500 sm:flex-row">
      <span>ClawFarm — open source, Apache-2.0 licensed</span>
      <div class="flex items-center gap-6">
        <a href="https://github.com/clawfarm/clawfarm" class="transition hover:text-zinc-300">GitHub</a>
        <a href="https://github.com/clawfarm/clawfarm/blob/master/CONTRIBUTING.md" class="transition hover:text-zinc-300">Contributing</a>
        <span class="text-zinc-600">·</span>
        <span>Built by <a href="https://gitter.ai" class="transition hover:text-zinc-300">Ben Gitter</a></span>
      </div>
    </div>
  </footer>
</Layout>
