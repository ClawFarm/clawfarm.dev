---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: 'Container Isolation',
    description: 'Each agent runs in its own Docker container and network. Agents can\'t see each other or reach your LAN.',
    icon: 'shield',
  },
  {
    title: 'Multi-User RBAC',
    description: 'Per-agent access control enforced at the reverse proxy layer. Users only see and manage their own agents.',
    icon: 'users',
  },
  {
    title: 'Backup & Rollback',
    description: 'Scheduled hourly backups with configurable retention. One-click restore to any previous state.',
    icon: 'archive',
  },
  {
    title: 'Zero-Config HTTPS',
    description: 'Caddy handles TLS termination with path-based routing under a single port. Four modes from self-signed to Let\'s Encrypt.',
    icon: 'lock',
  },
  {
    title: 'Web Terminal',
    description: 'Interactive shell into any running agent container, directly from the dashboard. No SSH or docker exec needed.',
    icon: 'terminal',
  },
  {
    title: 'Monitoring',
    description: 'CPU, memory, storage, and token usage per agent. Fleet-wide stats at a glance from the dashboard.',
    icon: 'chart',
  },
  {
    title: 'Templates',
    description: 'Define reusable agent configs with environment variable substitution. Create new agents in seconds.',
    icon: 'template',
  },
];

const iconPaths: Record<string, string> = {
  shield: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  users: '<path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M22 21v-2a4 4 0 0 0-3-3.87"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  archive: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 8v13H3V8"/><rect x="1" y="3" width="22" height="5" rx="1"/><path stroke-linecap="round" stroke-linejoin="round" d="M10 12h4"/>',
  lock: '<rect x="3" y="11" width="18" height="11" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  chart: '<path stroke-linecap="round" stroke-linejoin="round" d="M18 20V10M12 20V4M6 20v-6"/>',
  template: '<rect x="3" y="3" width="18" height="18" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 9h18M9 21V9"/>',
};

const tlsModes = [
  {
    name: 'Internal',
    description: 'Auto-generated self-signed cert. Zero config — just deploy.',
    default: true,
  },
  {
    name: 'ACME',
    description: 'Automatic Let\'s Encrypt certificates. Set your domain and go.',
    default: false,
  },
  {
    name: 'Custom',
    description: 'Bring your own certs from an existing PKI or corporate CA.',
    default: false,
  },
  {
    name: 'Off',
    description: 'Plain HTTP. For when ClawFarm sits behind nginx, Traefik, or Cloudflare.',
    default: false,
  },
];
---

<Layout
  title="ClawFarm — Self-hosted fleet manager for OpenClaw AI agents"
  description="Deploy, monitor, and manage autonomous OpenClaw AI agents on your own hardware. Container isolation, multi-user RBAC, web terminal, backup/rollback, zero-config HTTPS."
>
  <!-- Nav -->
  <nav class="fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2.5 text-lg font-semibold tracking-tight">
        <img src="/logo.svg" alt="" class="h-7 w-7" />
        ClawFarm
      </a>

      <!-- Desktop links -->
      <div class="hidden items-center gap-6 text-sm text-zinc-400 sm:flex">
        <a href="#features" class="transition hover:text-zinc-100">Features</a>
        <a href="#deploy" class="transition hover:text-zinc-100">Deploy</a>
        <a href="https://github.com/clawfarm/clawfarm" class="flex items-center gap-1.5 transition hover:text-zinc-100">
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
          GitHub
        </a>
      </div>

      <!-- Hamburger (mobile) -->
      <button
        id="nav-toggle"
        class="flex h-9 w-9 items-center justify-center rounded-md border border-zinc-800 text-zinc-400 transition hover:text-zinc-100 sm:hidden"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg id="icon-menu" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="nav-menu" class="hidden border-t border-zinc-800/50 bg-zinc-950/95 backdrop-blur-md sm:hidden">
      <div class="mx-auto max-w-6xl space-y-1 px-6 py-4">
        <a href="#features" class="block rounded-md px-3 py-2 text-sm text-zinc-400 transition hover:bg-zinc-900 hover:text-zinc-100">Features</a>
        <a href="#deploy" class="block rounded-md px-3 py-2 text-sm text-zinc-400 transition hover:bg-zinc-900 hover:text-zinc-100">Deploy</a>
        <a href="#quickstart" class="block rounded-md px-3 py-2 text-sm text-zinc-400 transition hover:bg-zinc-900 hover:text-zinc-100">Quick Start</a>
        <a href="https://github.com/clawfarm/clawfarm" class="block rounded-md px-3 py-2 text-sm text-zinc-400 transition hover:bg-zinc-900 hover:text-zinc-100">GitHub</a>
      </div>
    </div>
  </nav>

  <script>
    const navToggle = document.getElementById('nav-toggle');
    const navMenu = document.getElementById('nav-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');

    navToggle?.addEventListener('click', () => {
      const isOpen = !navMenu?.classList.contains('hidden');
      navMenu?.classList.toggle('hidden');
      iconMenu?.classList.toggle('hidden');
      iconClose?.classList.toggle('hidden');
      navToggle.setAttribute('aria-expanded', String(!isOpen));
    });

    navMenu?.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener('click', () => {
        navMenu.classList.add('hidden');
        iconMenu?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        navToggle?.setAttribute('aria-expanded', 'false');
      });
    });
  </script>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
      <!-- Gradient glows -->
      <div class="pointer-events-none absolute -top-40 -right-20 h-[600px] w-[600px] rounded-full bg-blue-500/10 blur-[100px] animate-pulse-glow"></div>
      <div class="pointer-events-none absolute -bottom-20 -left-40 h-[400px] w-[400px] rounded-full bg-blue-600/8 blur-[80px] animate-pulse-glow" style="animation-delay: 1.5s;"></div>

      <!-- Dot grid background -->
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 24px 24px;"></div>

      <div class="mx-auto max-w-6xl px-6">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <!-- Left: text -->
          <div class="animate-fade-up">
            <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900/80 px-4 py-1.5 text-sm text-zinc-400">
              <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
              Open Source &middot; Self-Hosted
            </div>

            <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
              Self-hosted fleet manager for
              <span class="bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent">OpenClaw</span>
              AI agents
            </h1>
            <p class="mt-6 max-w-xl text-lg leading-relaxed text-zinc-400">
              OpenClaw is a powerful autonomous AI agent — but it's built for one operator, one instance, one CLI.
              ClawFarm gives you a web dashboard to deploy, isolate, and manage a fleet of them on your own hardware.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-4">
              <a
                href="#quickstart"
                class="group rounded-lg bg-blue-600 px-6 py-3 text-sm font-medium transition hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-500/25"
              >
                Get Started
                <span class="ml-1 inline-block transition-transform group-hover:translate-x-0.5">&rarr;</span>
              </a>
              <a
                href="https://github.com/clawfarm/clawfarm"
                class="rounded-lg border border-zinc-700 px-6 py-3 text-sm font-medium text-zinc-300 transition hover:border-zinc-500 hover:text-zinc-100"
              >
                View on GitHub
              </a>
            </div>

            <!-- Trust stats -->
            <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-2 text-sm text-zinc-500">
              <div><span class="font-semibold text-zinc-200">100%</span> Docker</div>
              <div class="hidden h-4 w-px bg-zinc-800 sm:block"></div>
              <div><span class="font-semibold text-zinc-200">3</span> commands to deploy</div>
              <div class="hidden h-4 w-px bg-zinc-800 sm:block"></div>
              <div><span class="font-semibold text-zinc-200">Apache-2.0</span> licensed</div>
            </div>
          </div>

          <!-- Right: mobile screenshot -->
          <div class="relative hidden animate-slide-in-right lg:flex lg:justify-center">
            <div class="relative mx-auto max-w-[280px]">
              <div class="overflow-hidden rounded-2xl border border-zinc-800 shadow-2xl shadow-blue-500/10">
                <img
                  src="/screenshots/dashboard-mobile.png"
                  alt="ClawFarm mobile dashboard showing fleet management"
                  class="w-full"
                />
              </div>

              <!-- Floating badges -->
              <div class="absolute -top-4 -right-8 rounded-lg border border-zinc-700/50 bg-zinc-900/90 px-3 py-2 text-xs shadow-lg backdrop-blur-sm animate-float">
                <span class="text-green-400">&#9679;</span> <span class="text-zinc-400">3 agents running</span>
              </div>
              <div class="absolute -bottom-3 -left-8 rounded-lg border border-zinc-700/50 bg-zinc-900/90 px-3 py-2 text-xs shadow-lg backdrop-blur-sm animate-float" style="animation-delay: 2s;">
                <span class="text-blue-400">&#9679;</span> <span class="text-zinc-400">1.2M tokens used</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Screenshots -->
    <section class="mx-auto max-w-6xl px-6 pb-24">
      <!-- Device toggle -->
      <div class="mb-6 flex items-center justify-end">
        <div class="inline-flex rounded-lg border border-zinc-800 bg-zinc-900/50 p-1" id="device-toggle">
          <button
            data-device="desktop"
            class="rounded-md px-3 py-1.5 text-sm font-medium transition bg-zinc-700 text-zinc-100"
          >
            <svg class="mr-1.5 inline-block h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8m-4-4v4" /></svg>
            Desktop
          </button>
          <button
            data-device="mobile"
            class="rounded-md px-3 py-1.5 text-sm font-medium transition text-zinc-400 hover:text-zinc-200"
          >
            <svg class="mr-1.5 inline-block h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" /><path d="M12 18h.01" /></svg>
            Mobile
          </button>
        </div>
      </div>

      <!-- Desktop screenshots -->
      <div id="screenshots-desktop" class="space-y-6">
        <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5 transition-shadow hover:shadow-blue-500/10">
          <img
            src="/screenshots/dashboard-desktop.png"
            alt="ClawFarm dashboard showing a fleet of running AI agents with token usage chart and sparklines"
            class="w-full"
            loading="lazy"
          />
        </div>
        <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5 transition-shadow hover:shadow-blue-500/10">
          <img
            src="/screenshots/create-agent-desktop.png"
            alt="Creating a new agent with template selection and personality configuration"
            class="w-full"
            loading="lazy"
          />
        </div>
        <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5 transition-shadow hover:shadow-blue-500/10">
          <img
            src="/screenshots/detail-desktop.png"
            alt="Agent detail page with live metrics, token usage, cron jobs, and backups"
            class="w-full"
            loading="lazy"
          />
        </div>
        <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5 transition-shadow hover:shadow-blue-500/10">
          <img
            src="/screenshots/terminal-desktop.png"
            alt="Web terminal with interactive shell into a running agent"
            class="w-full"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Mobile screenshots -->
      <div id="screenshots-mobile" class="hidden">
        <div class="mx-auto grid max-w-2xl grid-cols-2 gap-6 sm:grid-cols-4">
          <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5">
            <img
              src="/screenshots/dashboard-mobile.png"
              alt="ClawFarm mobile dashboard"
              class="w-full"
              loading="lazy"
            />
          </div>
          <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5">
            <img
              src="/screenshots/create-agent-mobile.png"
              alt="ClawFarm mobile create agent"
              class="w-full"
              loading="lazy"
            />
          </div>
          <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5">
            <img
              src="/screenshots/detail-mobile.png"
              alt="ClawFarm mobile agent detail"
              class="w-full"
              loading="lazy"
            />
          </div>
          <div class="overflow-hidden rounded-xl border border-zinc-800 shadow-2xl shadow-blue-500/5">
            <img
              src="/screenshots/terminal-mobile.png"
              alt="ClawFarm mobile web terminal"
              class="w-full"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <script>
      const toggle = document.getElementById('device-toggle');
      const desktopPane = document.getElementById('screenshots-desktop');
      const mobilePane = document.getElementById('screenshots-mobile');
      toggle?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button[data-device]') as HTMLButtonElement | null;
        if (!btn) return;
        const device = btn.dataset.device;
        const buttons = toggle.querySelectorAll('button[data-device]');
        buttons.forEach((b) => {
          if (b.getAttribute('data-device') === device) {
            b.className = 'rounded-md px-3 py-1.5 text-sm font-medium transition bg-zinc-700 text-zinc-100';
          } else {
            b.className = 'rounded-md px-3 py-1.5 text-sm font-medium transition text-zinc-400 hover:text-zinc-200';
          }
        });
        if (device === 'mobile') {
          desktopPane?.classList.add('hidden');
          mobilePane?.classList.remove('hidden');
        } else {
          desktopPane?.classList.remove('hidden');
          mobilePane?.classList.add('hidden');
        }
      });
    </script>

    <!-- Quick Start -->
    <section id="quickstart" class="relative py-20 sm:py-28">
      <div class="absolute inset-0 bg-zinc-900/30"></div>
      <div class="relative mx-auto max-w-6xl px-6">
        <h2 class="reveal text-2xl font-bold tracking-tight sm:text-3xl">Quick Start</h2>
        <p class="reveal mt-3 max-w-2xl text-zinc-400">Three commands. No TLS certificates to generate, no Docker GID to look up.</p>
        <div class="reveal mt-8">
          <div class="relative rounded-lg p-px bg-gradient-to-b from-zinc-700 via-zinc-800 to-zinc-800">
            <div class="rounded-lg bg-zinc-900">
              <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-2.5 text-xs text-zinc-500">
                <span class="h-2.5 w-2.5 rounded-full bg-red-500/60"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/60"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-green-500/60"></span>
                <span class="ml-2">terminal</span>
              </div>
              <pre class="overflow-x-auto p-5 text-sm leading-relaxed"><code class="text-zinc-300"><span class="text-zinc-500"># Clone & configure</span>
<span class="text-blue-400">$</span> git clone https://github.com/clawfarm/clawfarm && cd clawfarm
<span class="text-blue-400">$</span> cp .env.example .env   <span class="text-zinc-500"># add your LLM provider details</span>

<span class="text-zinc-500"># Launch</span>
<span class="text-blue-400">$</span> docker compose up -d

<span class="text-zinc-500"># Open https://&lt;your-ip&gt;:8443</span>
<span class="text-zinc-500"># Admin password: docker compose logs dashboard | head -20</span></code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gradient separator -->
    <div class="mx-auto max-w-6xl px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
    </div>

    <!-- Features -->
    <section id="features" class="py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center">
          <h2 class="reveal text-2xl font-bold tracking-tight sm:text-3xl">What you get</h2>
          <p class="reveal mx-auto mt-3 max-w-2xl text-zinc-400">
            Everything you need to run a fleet of AI agents. The AI capabilities are 100% OpenClaw — ClawFarm handles the operational infrastructure.
          </p>
        </div>
        <div class="reveal-stagger mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {features.map((f) => (
            <div class="reveal group rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 transition-all duration-300 hover:border-zinc-700 hover:bg-zinc-900/80 hover:-translate-y-1 hover:shadow-lg hover:shadow-blue-500/5">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-blue-500/10 text-blue-400 transition-colors duration-300 group-hover:bg-blue-500/20">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <Fragment set:html={iconPaths[f.icon]} />
                </svg>
              </div>
              <h3 class="text-lg font-semibold">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-zinc-400">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Gradient separator -->
    <div class="mx-auto max-w-6xl px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
    </div>

    <!-- Deployment Modes -->
    <section id="deploy" class="py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="reveal text-2xl font-bold tracking-tight sm:text-3xl">Deployment Modes</h2>
        <p class="reveal mt-3 max-w-2xl text-zinc-400">
          Four TLS modes to fit your setup. Caddy handles all of it — you just set one env var.
        </p>
        <div class="mt-12 grid gap-6 lg:grid-cols-5">
          <!-- Featured: default mode -->
          <div class="reveal lg:col-span-2 rounded-xl border border-blue-500/20 bg-blue-500/5 p-6">
            <span class="rounded-full bg-blue-500/10 px-2 py-0.5 text-xs font-medium text-blue-400">default</span>
            <h3 class="mt-3 text-xl font-semibold">Internal</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">Auto-generated self-signed cert. Zero config — just deploy.</p>
            <p class="mt-4 text-xs text-zinc-500">Works out of the box. No DNS required.</p>
          </div>
          <!-- Other modes -->
          <div class="reveal-stagger lg:col-span-3 grid gap-4 sm:grid-cols-3">
            {tlsModes.filter((m) => !m.default).map((mode) => (
              <div class="reveal rounded-xl border border-zinc-800 bg-zinc-900/50 p-5 transition-all duration-300 hover:border-zinc-700">
                <h3 class="font-semibold">{mode.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-zinc-400">{mode.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Gradient separator -->
    <div class="mx-auto max-w-6xl px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
    </div>

    <!-- Provider Compatibility -->
    <section class="py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="reveal text-2xl font-bold tracking-tight sm:text-3xl">Works with any LLM</h2>
        <p class="reveal mt-3 max-w-2xl text-zinc-400">
          Built-in templates for major providers. Any OpenAI-compatible API works too — local or cloud.
        </p>
        <div class="reveal-stagger mt-12 grid gap-6 sm:grid-cols-3">
          <div class="reveal group rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 transition-all duration-300 hover:border-zinc-700">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-purple-500/10 text-purple-400">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <h3 class="font-semibold">Cloud APIs</h3>
            <p class="mt-2 text-sm text-zinc-400">Anthropic Claude, OpenAI GPT, MiniMax, Qwen — one template per provider, just add an API key.</p>
          </div>
          <div class="reveal group rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 transition-all duration-300 hover:border-zinc-700">
